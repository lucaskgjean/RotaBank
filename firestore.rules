rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: rotabank_expenses
    // Document ID: auto-generated
    // Fields:
    //   - amount: number (required, > 0)
    //   - category: string (required, enum)
    //   - description: string (optional, max 100 chars)
    //   - date: string (required, ISO 8601 format)
    //   - uid: string (required, owner UID)
    //
    // Collection: entries
    // Document ID: auto-generated
    // Fields:
    //   - netAmount: number (required, > 0)
    //   - description: string (optional)
    //   - date: string (optional, ISO 8601 format)
    //   - uid: string (required, owner UID)
    //
    // Collection: users
    // Document ID: user UID
    // Fields:
    //   - email: string
    //   - displayName: string
    //   - role: string ('admin' or 'client')
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (request.auth.token.email == "jeanlucasgontijo.15@gmail.com" && request.auth.token.email_verified == true) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidExpense(data) {
      return hasOnlyAllowedFields(['amount', 'category', 'description', 'date', 'uid']) &&
             data.amount is number && data.amount > 0 &&
             data.category is string && data.category.size() > 0 && data.category.size() < 50 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 100)) &&
             data.date is string && data.date.matches("^\\d{4}-\\d{2}-\\d{2}.*") &&
             data.uid == request.auth.uid;
    }

    function isValidEntry(data) {
      return hasOnlyAllowedFields(['netAmount', 'description', 'date', 'uid']) &&
             data.netAmount is number && data.netAmount > 0 &&
             data.uid == request.auth.uid;
    }

    function isValidUser(data) {
      return hasOnlyAllowedFields(['email', 'displayName', 'role']) &&
             data.email is string && data.role in ['admin', 'client'];
    }

    // Rules
    match /rotabank_expenses/{expenseId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && hasRequiredFields(['amount', 'category', 'date', 'uid']) && isValidExpense(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin()) && isValidExpense(request.resource.data) && uidNotModified();
      allow delete: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
    }

    match /entries/{entryId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      // RotaBank only reads entries from Rota Financeira as a mirror.
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'client';
      allow update: if isAuthenticated() && (isAdmin() || (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role));
      allow delete: if isAdmin();
    }
  }
}
