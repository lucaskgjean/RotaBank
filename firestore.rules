rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: rotabank_expenses
    // Document ID: auto-generated
    // Fields:
    //   - amount: number (required, > 0)
    //   - category: string (required, enum)
    //   - description: string (optional, max 100 chars)
    //   - date: string (required, ISO 8601 format)
    //   - uid: string (required, owner UID)
    //
    // Collection: entries
    // Document ID: auto-generated
    // Fields:
    //   - netAmount: number (required, > 0)
    //   - description: string (optional)
    //   - date: string (optional, ISO 8601 format)
    //   - uid: string (required, owner UID)
    //
    // Collection: users
    // Document ID: user UID
    // Fields:
    //   - email: string
    //   - displayName: string
    //   - role: string ('admin' or 'client')
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          request.auth.token.email == "jeanlucasgontijo.15@gmail.com" ||
          request.auth.token.email == "jeangontijoo@gmail.com" ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function isValidExpense(data) {
      return data.amount is number && data.amount > 0 &&
             data.category is string && data.category.size() > 0 &&
             data.date is string &&
             data.uid == request.auth.uid;
    }

    function isValidUser(data) {
      return data.email is string && data.role in ['admin', 'client'];
    }

    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Rules
    match /rotabank_expenses/{expenseId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidExpense(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.uid == request.auth.uid || request.auth.token.email == "jeanlucasgontijo.15@gmail.com" || request.auth.token.email == "jeangontijoo@gmail.com") && isValidExpense(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.uid == request.auth.uid || request.auth.token.email == "jeanlucasgontijo.15@gmail.com" || request.auth.token.email == "jeangontijoo@gmail.com");
    }

    match /entries/{entryId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || request.auth.token.email == "jeanlucasgontijo.15@gmail.com");
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'client';
      allow update: if isAuthenticated() && (request.auth.token.email == "jeanlucasgontijo.15@gmail.com" || (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role));
      allow delete: if request.auth.token.email == "jeanlucasgontijo.15@gmail.com";
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
